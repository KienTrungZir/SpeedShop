@model DonHang
@{
    ViewData["Title"] = $"Đơn {Model.MaDonHang}";
}

<h2 class="mb-3">Chi tiết đơn hàng</h2>

<div class="row mb-4">
    <div class="col-md-6">
        <p><strong>Mã đơn:</strong> @Model.MaDonHang</p>
        <p><strong>Khách:</strong> @Model.HoTenNguoiNhan (@Model.User?.Email)</p>
        <p><strong>SĐT:</strong> @Model.SoDienThoai</p>
        <p><strong>Địa chỉ:</strong> @Model.DiaChiGiao, @Model.PhuongXa, @Model.QuanHuyen, @Model.TinhThanh</p>
    </div>
    <div class="col-md-6">
        <p><strong>Ngày đặt:</strong> @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Thanh toán:</strong> @Model.PhuongThucThanhToan</p>
        <p><strong>Trạng thái:</strong> <span class="badge bg-primary">@Model.TrangThai</span></p>
    </div>
</div>

<table class="table table-bordered mb-4">
    <thead class="table-light">
        <tr><th>Sản phẩm</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr>
    </thead>
    <tbody>
        @foreach (var ct in Model.ChiTietDonHangs)
        {
            <tr>
                <td>@ct.TenSanPham @if (!string.IsNullOrEmpty(ct.TenBienThe)) { <small>(@ct.TenBienThe)</small> }</td>
                <td>@ct.SoLuong</td>
                <td>@ct.DonGia.ToString("N0")đ</td>
                <td>@ct.ThanhTien.ToString("N0")đ</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr><td colspan="3" class="text-end">Tổng thanh toán</td><td class="fw-bold text-danger">@Model.TongThanhToan.ToString("N0")đ</td></tr>
    </tfoot>
</table>

<form asp-action="CapNhatTrangThai" method="post" class="row g-2 align-items-end">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="col-auto">
        <label class="form-label">Cập nhật trạng thái</label>
        <select name="trangThai" class="form-select" asp-for="TrangThai" asp-items="Html.GetEnumSelectList<TrangThaiDonHang>()"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Lưu</button>
    </div>
</form>

<a asp-action="Index" class="btn btn-secondary mt-3">← Quay lại</a>
