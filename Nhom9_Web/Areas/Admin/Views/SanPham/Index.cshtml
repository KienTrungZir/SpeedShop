@model List<SanPham>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Sản phẩm</h2>
    <a asp-action="Tao" class="btn btn-primary">+ Thêm sản phẩm</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tên</th>
                <th>Danh mục</th>
                <th>Thương hiệu</th>
                <th>Giá bán</th>
                <th>Tồn</th>
                <th>Hiển thị</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sp in Model)
            {
                <tr>
                    <td>@sp.Id</td>
                    <td>@sp.TenSanPham</td>
                    <td>@sp.DanhMuc.TenDanhMuc</td>
                    <td>@sp.ThuongHieu.TenThuongHieu</td>
                    <td>@sp.GiaBan.ToString("N0")đ</td>
                    <td>@sp.SoLuongTon</td>
                    <td>@(sp.HienThi ? "✓" : "✗")</td>
                    <td class="text-nowrap">
                        <a asp-action="Sua" asp-route-id="@sp.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <form asp-action="Xoa" asp-route-id="@sp.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa sản phẩm này?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
