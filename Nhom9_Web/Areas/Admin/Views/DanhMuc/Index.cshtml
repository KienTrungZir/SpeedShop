@model List<DanhMuc>
@{
    ViewData["Title"] = "Danh mục";
}

<div class="d-flex justify-content-between mb-3">
    <h2>Danh mục</h2>
    <a asp-action="Tao" class="btn btn-primary">+ Thêm</a>
</div>

<table class="table table-bordered">
    <thead class="table-light"><tr><th>ID</th><th>Tên</th><th>Thứ tự</th><th>Hiển thị</th><th></th></tr></thead>
    <tbody>
        @foreach (var dm in Model)
        {
            <tr>
                <td>@dm.Id</td>
                <td>@dm.TenDanhMuc</td>
                <td>@dm.ThuTu</td>
                <td>@(dm.HienThi ? "✓" : "✗")</td>
                <td>
                    <a asp-action="Sua" asp-route-id="@dm.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                    <form asp-action="Xoa" asp-route-id="@dm.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa?');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
