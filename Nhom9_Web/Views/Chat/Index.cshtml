@model List<HoiThoaiViewModel>
@{
    ViewData["Title"] = "Tin nhắn";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">💬 Tin nhắn</h2>
</div>

@if (Model.Any())
{
    <div class="list-group shadow-sm">
        @foreach (var ht in Model)
        {
            <a asp-action="TroChuyen" asp-route-id="@ht.DoiTacId"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-start py-3">
                <div class="me-auto">
                    <div class="fw-semibold">@ht.DoiTacTen</div>
                    @if (!string.IsNullOrEmpty(ht.DoiTacEmail))
                    {
                        <small class="text-muted">@ht.DoiTacEmail</small>
                    }
                    @if (!string.IsNullOrEmpty(ht.TinNhanCuoi))
                    {
                        <p class="mb-0 text-muted small text-truncate" style="max-width:400px">@ht.TinNhanCuoi</p>
                    }
                    else
                    {
                        <p class="mb-0 text-muted small">Bắt đầu cuộc trò chuyện...</p>
                    }
                </div>
                <div class="text-end ms-3">
                    @if (ht.ThoiGianCuoi.HasValue)
                    {
                        <small class="text-muted d-block">@ht.ThoiGianCuoi.Value.ToLocalTime().ToString("dd/MM HH:mm")</small>
                    }
                    @if (ht.SoTinChuaDoc > 0)
                    {
                        <span class="badge bg-danger rounded-pill mt-1">@ht.SoTinChuaDoc</span>
                    }
                </div>
            </a>
        }
    </div>
}
else
{
    <div class="alert alert-info">Chưa có cuộc trò chuyện nào.</div>
}
