@inject Nhom9_Web.Services.GioHangSessionService GioHangService
@inject Nhom9_Web.Services.ChatService ChatService
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cầu Lông Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Nhom9_Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">🏸 Cầu Lông Shop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SanPham" asp-action="Index">Sản phẩm</a>
                        </li>
                    </ul>
                    <form class="d-flex me-3" asp-controller="SanPham" asp-action="Index" method="get">
                        <input class="form-control form-control-sm me-2" type="search" name="tuKhoa" placeholder="Tìm vợt, giày, cầu..." />
                        <button class="btn btn-outline-light btn-sm" type="submit">Tìm</button>
                    </form>
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="GioHang" asp-action="Index">
                                🛒 Giỏ hàng
                                @{
                                    var soLuong = GioHangService.DemSoLuong();
                                }
                                @if (soLuong > 0)
                                {
                                    <span class="badge bg-warning text-dark cart-badge">@soLuong</span>
                                }
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var tinChuaDoc = await ChatService.DemTinChuaDocAsync(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Chat" asp-action="Index">
                                    💬 Tin nhắn
                                    @if (tinChuaDoc > 0)
                                    {
                                        <span class="badge bg-danger chat-badge">@tinChuaDoc</span>
                                    }
                                </a>
                            </li>
                            @if (User.IsInRole(AppRoles.Admin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning fw-semibold" asp-area="Admin" asp-controller="Home" asp-action="Index">Quản trị</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="DonHang" asp-action="LichSu">Đơn hàng</a>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-3">
        @if (TempData["ThanhCong"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["ThanhCong"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Loi"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Loi"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer bg-dark text-light py-3 mt-auto">
        <div class="container text-center">
            <p class="mb-0 small text-secondary">&copy; @DateTime.Now.Year - SpeedShop</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
