@model GioHangViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2 class="section-title mb-4">Giỏ hàng (@Model.TongSoLuong sản phẩm)</h2>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead class="table-light">
                <tr>
                    <th>Sản phẩm</th>
                    <th class="text-end">Đơn giá</th>
                    <th class="text-center" style="width:140px">Số lượng</th>
                    <th class="text-end">Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(item.AnhDaiDien))
                                {
                                    <img src="@item.AnhDaiDien" width="60" height="60" class="rounded object-fit-cover" alt="" />
                                }
                                <div>
                                    <a asp-controller="SanPham" asp-action="ChiTiet" asp-route-id="@item.SanPhamId" class="fw-semibold text-decoration-none">
                                        @item.TenSanPham
                                    </a>
                                    @if (!string.IsNullOrEmpty(item.TenBienThe))
                                    {
                                        <div class="small text-muted">@item.TenBienThe</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="text-end">@item.DonGia.ToString("N0")đ</td>
                        <td>
                            <form asp-action="CapNhat" method="post" class="d-flex gap-1 justify-content-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sanPhamId" value="@item.SanPhamId" />
                                <input type="hidden" name="bienTheId" value="@item.BienTheSanPhamId" />
                                <input type="number" name="soLuong" value="@item.SoLuong" min="1" max="@item.SoLuongTon" class="form-control form-control-sm" style="width:70px" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">✓</button>
                            </form>
                        </td>
                        <td class="text-end fw-semibold">@item.ThanhTien.ToString("N0")đ</td>
                        <td>
                            <form asp-action="Xoa" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sanPhamId" value="@item.SanPhamId" />
                                <input type="hidden" name="bienTheId" value="@item.BienTheSanPhamId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                    <td class="text-end fw-bold text-danger fs-5">@Model.TongTien.ToString("N0")đ</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="d-flex justify-content-between mt-3">
        <a asp-controller="SanPham" asp-action="Index" class="btn btn-outline-primary">← Tiếp tục mua sắm</a>
        <a asp-controller="DonHang" asp-action="ThanhToan" class="btn btn-primary btn-lg">Thanh toán</a>
    </div>
}
else
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">Giỏ hàng của bạn đang trống.</p>
        <a asp-controller="SanPham" asp-action="Index" class="btn btn-primary">Xem sản phẩm</a>
    </div>
}
