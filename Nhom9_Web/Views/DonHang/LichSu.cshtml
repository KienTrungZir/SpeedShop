@model List<DonHang>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<h2 class="section-title mb-4">Lịch sử đơn hàng</h2>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã đơn</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dh in Model)
                {
                    <tr>
                        <td class="fw-semibold">@dh.MaDonHang</td>
                        <td>@dh.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-danger fw-semibold">@dh.TongThanhToan.ToString("N0")đ</td>
                        <td><span class="badge bg-secondary">@dh.TrangThai</span></td>
                        <td>
                            <a asp-action="ChiTiet" asp-route-id="@dh.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">Bạn chưa có đơn hàng nào.</div>
}
