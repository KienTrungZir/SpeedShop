@model DonHang
@{
    ViewData["Title"] = $"Đơn hàng {Model.MaDonHang}";
}
<!--  -->
<div class="text-center mb-4">
    <div class="display-1 text-success">✓</div>
    <h2>Đặt hàng thành công!</h2>
    <p class="text-muted">Mã đơn hàng: <strong>@Model.MaDonHang</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header d-flex justify-content-between">
                <span class="fw-bold">Chi tiết đơn hàng</span>
                <span class="badge bg-primary">@Model.TrangThai</span>
            </div>
            <div class="card-body">
                <div class="row mb-3 small">
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Người nhận:</strong> @Model.HoTenNguoiNhan</p>
                        <p class="mb-1"><strong>SĐT:</strong> @Model.SoDienThoai</p>
                        <p class="mb-0"><strong>Địa chỉ:</strong> @Model.DiaChiGiao, @Model.PhuongXa, @Model.QuanHuyen, @Model.TinhThanh</p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Ngày đặt:</strong> @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="mb-1"><strong>Thanh toán:</strong> @Model.PhuongThucThanhToan</p>
                        @if (!string.IsNullOrEmpty(Model.GhiChu))
                        {
                            <p class="mb-0"><strong>Ghi chú:</strong> @Model.GhiChu</p>
                        }
                    </div>
                </div>

                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">SL</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ct in Model.ChiTietDonHangs)
                        {
                            <tr>
                                <td>
                                    @ct.TenSanPham
                                    @if (!string.IsNullOrEmpty(ct.TenBienThe))
                                    {
                                        <small class="text-muted">(@ct.TenBienThe)</small>
                                    }
                                </td>
                                <td class="text-center">@ct.SoLuong</td>
                                <td class="text-end">@ct.DonGia.ToString("N0")đ</td>
                                <td class="text-end">@ct.ThanhTien.ToString("N0")đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><td colspan="3" class="text-end">Tạm tính</td><td class="text-end">@Model.TongTienHang.ToString("N0")đ</td></tr>
                        <tr><td colspan="3" class="text-end">Phí vận chuyển</td><td class="text-end">@Model.PhiVanChuyen.ToString("N0")đ</td></tr>
                        @if (Model.GiamGia > 0)
                        {
                            <tr><td colspan="3" class="text-end text-success">Giảm giá</td><td class="text-end text-success">-@Model.GiamGia.ToString("N0")đ</td></tr>
                        }
                        <tr class="fw-bold"><td colspan="3" class="text-end">Tổng cộng</td><td class="text-end text-danger">@Model.TongThanhToan.ToString("N0")đ</td></tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="text-center">
            <a asp-controller="SanPham" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
            <a asp-controller="DonHang" asp-action="LichSu" class="btn btn-outline-secondary">Xem đơn hàng</a>
        </div>
    </div>
</div>
